            <circle cx=3D"12" cy=3D"14" r=3D"5" stroke=3D"#2557d6" stroke-w=
idth=3D"2"></circle>
            <circle cx=3D"26" cy=3D"10" r=3D"4" stroke=3D"#2557d6" stroke-w=
