            <path d=3D"M5 28L12 18l7 5 7-10 5 4" stroke=3D"#7c3aed" stroke-=
width=3D"2" stroke-linecap=3D"round" stroke-linejoin=3D"round"></path>
            <path d=3D"M5 8h2M5 14h2M5 20h2M5 26h2" stroke=3D"#7c3aed" stro=
